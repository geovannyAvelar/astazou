# Compose-level ports
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Postgres (external) - point these to your external DB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shalom
DB_USER=postgres
DB_PASSWORD=postgres

# Spring
SPRING_PROFILES_ACTIVE=default

# Frontend
# Set this to the backend URL that the frontend will call (including protocol and port if needed)
NEXT_PUBLIC_API_URL=http://localhost:8080